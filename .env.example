# Copy to .env and fill with real values. Do not commit .env.
# All paths in Supabase Dashboard.

# Postgres connection (Pooler, transaction mode, port 6543) — for app runtime
# Dashboard → Project Settings → Database → Connection string → "Transaction"
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Direct Postgres connection (port 5432) — for migrations / DDL
# Pooler doesn't support session-level state needed by CREATE TABLE etc.
# Dashboard → Project Settings → Database → Connection string → "Direct connection"
DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Supabase REST endpoint (used by Storage SDK in later phases)
# Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://<ref>.supabase.co

# Service role secret — bypasses RLS, used for migrations & server-side ops
# Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_KEY=

# JWT signing key for peer tokens — independent of Supabase
# Generate: openssl rand -hex 32
JWT_SIGNING_KEY=
